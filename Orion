-- 5. タブ切り替え機能の移植 (Orion X仕様)
function OrionLib:GoToTab(tabName)
	for name, data in pairs(Tabs) do
		if data.Frame and data.Container then
			if name == tabName then
				data.Container.Visible = true
				if data.Frame:FindFirstChild("Title") then
					data.Frame.Title.Font = Enum.Font.GothamBlack
					data.Frame.Title.TextTransparency = 0
				end
			else
				data.Container.Visible = false
				if data.Frame:FindFirstChild("Title") then
					data.Frame.Title.Font = Enum.Font.GothamSemibold
					data.Frame.Title.TextTransparency = 0.4
				end
			end
		end
	end
end

